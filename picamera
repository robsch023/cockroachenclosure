from picamera2 import PiCamera2, Preview
from time import sleep, ctime, time

camera = PiCamera2()

def capturephoto():
    datetime = ctime(time())
    camera.start_preview()
    camera.start()
    #sleep of min 2 seconds may cause the photo to be too delayed.
    #wakeup on detection of motion instead of on detection of RFID might be better
    sleep(1)
    camera.capture('/home/pi/Desktop/data/image%s.jpg' % datetime)
    camera.stop_preview()

